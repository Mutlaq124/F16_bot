# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.so
*.egg
*.egg-info/
dist/
build/
*.spec

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── LightRAG index & vector storage ─────────────────────────────────────────
# These are large binary files, regenerated by build_index.py
lightrag_neo4j_storage/
faiss_index/
*.pkl
*.bin
*.index
*.index.meta.json

# ─── Chunks (extracted by build_index.py --save-chunks, analysis only) ────────
chunks/

# ─── Documents / raw data ─────────────────────────────────────────────────────
# Never commit raw PDFs or proprietary docs
Docs/
PDF_Doc's/
F16_manual/
*.pdf
*.docx
Implement_docs.docx
deployment.md

# ─── Eval results (timestamped runs, not source code) ─────────────────────────
eval/results_*.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Streamlit secrets ────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ─── Jupyter ──────────────────────────────────────────────────────────────────
*.ipynb_checkpoints
.ipynb_checkpoints/

# ─── Temp / scratch ───────────────────────────────────────────────────────────
tmp/
temp/
scratch/
