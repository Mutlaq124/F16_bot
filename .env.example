# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ─── Groq (Inference LLM) ──────────────────────────────────────────────
# Get API key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Recommended model for high quality and speed:
GROQ_MODEL=llama-3.3-70b-versatile

#Evaluation:
OPENROUTER_API_KEY=openrouter_api_key_placeholder

# ─── Ollama (Build/Embedding LLM — local) ────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q8_0
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Neo4j ────────────────────────────────────────────────────────────────────
# Local Desktop:
# NEO4J_URI=bolt://localhost:7687

# Neo4j Aura (cloud) — use the neo4j+s:// URI from your Aura console:
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_aura_password_here

# ─── LightRAG Storage ─────────────────────────────────────────────────────────
RAG_WORKING_DIR=./lightrag_neo4j_storage

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
